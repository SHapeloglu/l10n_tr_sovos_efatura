<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kur_farki_wizard_form" model="ir.ui.view">
        <field name="name">sovos.kur.farki.wizard.form</field>
        <field name="model">sovos.kur.farki.wizard</field>
        <field name="arch" type="xml">
            <form string="Kur Farkı Faturası Oluştur">
                <group>
                    <field name="original_invoice_id" readonly="1"/>
                    <field name="kur_farki_date" required="1"/>
                    <field name="kur_farki_amount" required="1"/>
                    <field name="description"/>
                </group>
                <div class="alert alert-info" role="alert">
                    Kur farkı faturası taslak olarak oluşturulur.
                    Kontrol ettikten sonra e-Fatura olarak gönderebilirsiniz.
                </div>
                <footer>
                    <button name="action_create_kur_farki" string="Oluştur"
                            type="object" class="btn btn-primary"/>
                    <button string="İptal" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
