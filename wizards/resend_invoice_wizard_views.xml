<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resend_invoice_wizard_form" model="ir.ui.view">
        <field name="name">sovos.resend.invoice.wizard.form</field>
        <field name="model">sovos.resend.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="e-Fatura Tekrar Gönderim">
                <group>
                    <field name="invoice_id" readonly="1"/>
                    <field name="gib_status_code" readonly="1"/>
                    <field name="resend_type" widget="radio"/>
                    <field name="note" placeholder="Opsiyonel not..."/>
                </group>
                <div class="alert alert-warning" role="alert"
                     invisible="resend_type != 'new_invoice'">
                    İçerik değişikliği için önce faturayı iptal edin, ardından yeni fatura kesin.
                    Bu sihirbaz yalnızca teknik hata (aynı UUID) akışını destekler.
                </div>
                <footer>
                    <button name="action_resend" string="Tekrar Gönder"
                            type="object" class="btn btn-primary"
                            invisible="resend_type == 'new_invoice'"/>
                    <button string="İptal" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
